{
  "manifest_version": 3,
  "name": "WebTrace",
  "version": "1.0.0",
  "description": "Tracks websites you visit and syncs to your WebTrace dashboard.",
  "permissions": ["tabs", "storage", "alarms"],
  "host_permissions": ["http://localhost:5000/*", "https://your-api-domain.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "WebTrace"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
